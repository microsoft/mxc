{
    "$schema": "../schemas/dev/mxc-config.schema.0.6.0-dev.json",
    "version": "0.6.0-alpha",
    "containment": "seatbelt",
    "process": {
        "commandLine": "echo hi from seatbelt && pwd && id",
        "timeout": 10000
    },
    "filesystem": {
        "readwritePaths": ["/tmp"]
    },
    "network": {
        "defaultPolicy": "block"
    },
    "experimental": {
        "seatbelt": {
            "mode": "exec"
        }
    }
}
