{
    "$schema": "../schemas/dev/mxc-config.schema.0.5.0-dev.json",
    "version": "0.5.0-alpha",
    "containment": "macos_sandbox",
    "process": {
        "commandLine": "curl -s --max-time 5 https://example.com && echo NETWORK_ALLOWED || echo NETWORK_BLOCKED",
        "timeout": 10000
    },
    "filesystem": {
        "readwritePaths": ["/tmp"]
    },
    "network": {
        "defaultPolicy": "block"
    },
    "experimental": {
        "macos_sandbox": {
            "mode": "exec"
        }
    }
}
