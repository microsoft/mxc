{
    "$schema": "../schemas/dev/mxc-config.schema.0.5.0-dev.json",
    "version": "0.5.0-alpha",
    "containment": "macos_sandbox",
    "process": {
        "commandLine": "ls /Users/richiegomez/Documents && echo FS_ALLOWED || echo FS_BLOCKED",
        "timeout": 10000
    },
    "filesystem": {
        "readwritePaths": ["/tmp"],
        "deniedPaths": ["/Users/richiegomez/Documents"]
    },
    "network": {
        "defaultPolicy": "block"
    },
    "experimental": {
        "macos_sandbox": {
            "mode": "exec"
        }
    }
}
