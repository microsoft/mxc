{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/microsoft/mxc/schemas/dev/mxc-config.schema.0.8.0-dev.json",
  "title": "MXC Configuration",
  "description": "MXC container execution configuration. Defines the recommended config format for both one-shot and state-aware sandbox lifecycle requests. A few deprecated field spellings not listed here are also accepted via serde aliases.",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "Optional JSON Schema reference for editor validation. Accepted but ignored by the parser.",
      "type": [
        "string",
        "null"
      ]
    },
    "_comment": {
      "description": "Optional human-readable annotation. Accepted but ignored by the parser."
    },
    "containerId": {
      "description": "Externally assigned container identifier.",
      "type": [
        "string",
        "null"
      ]
    },
    "containment": {
      "description": "Containment backend to use for execution. Accepts abstract intents (`process`, `vm`) and concrete backends; the binary resolves intents to a concrete backend per host at run time.",
      "anyOf": [
        {
          "$ref": "#/definitions/Containment"
        },
        {
          "type": "null"
        }
      ]
    },
    "experimental": {
      "description": "Experimental features. Only honored when `--experimental` is passed.",
      "anyOf": [
        {
          "$ref": "#/definitions/Experimental"
        },
        {
          "type": "null"
        }
      ]
    },
    "fallback": {
      "description": "AppContainer DACL-mutation fallback policy (Windows).",
      "anyOf": [
        {
          "$ref": "#/definitions/Fallback"
        },
        {
          "type": "null"
        }
      ]
    },
    "filesystem": {
      "description": "Filesystem access policy. Shared across all backends.",
      "anyOf": [
        {
          "$ref": "#/definitions/Filesystem"
        },
        {
          "type": "null"
        }
      ]
    },
    "lifecycle": {
      "description": "Container lifecycle settings.",
      "anyOf": [
        {
          "$ref": "#/definitions/Lifecycle"
        },
        {
          "type": "null"
        }
      ]
    },
    "lxc": {
      "description": "LXC container settings (Linux). Used when containment is `lxc`.",
      "anyOf": [
        {
          "$ref": "#/definitions/Lxc"
        },
        {
          "type": "null"
        }
      ]
    },
    "network": {
      "description": "Network access policy. Shared across all backends.",
      "anyOf": [
        {
          "$ref": "#/definitions/Network"
        },
        {
          "type": "null"
        }
      ]
    },
    "phase": {
      "description": "State-aware lifecycle phase. When present, the request is a state-aware request (`sandboxId` is required for non-provision phases); when absent, the request is one-shot.",
      "anyOf": [
        {
          "$ref": "#/definitions/Phase"
        },
        {
          "type": "null"
        }
      ]
    },
    "process": {
      "description": "Process to execute and its environment.",
      "anyOf": [
        {
          "$ref": "#/definitions/Process"
        },
        {
          "type": "null"
        }
      ]
    },
    "processContainer": {
      "description": "ProcessContainer-specific settings (Windows). Used when containment is `processcontainer`.",
      "anyOf": [
        {
          "$ref": "#/definitions/ProcessContainer"
        },
        {
          "type": "null"
        }
      ]
    },
    "sandboxId": {
      "description": "Sandbox identifier returned by a prior provision request. Required for non-provision state-aware phases.",
      "type": [
        "string",
        "null"
      ]
    },
    "seatbelt": {
      "description": "macOS Seatbelt backend configuration. Used when containment is `seatbelt`.",
      "anyOf": [
        {
          "$ref": "#/definitions/Seatbelt"
        },
        {
          "type": "null"
        }
      ]
    },
    "ui": {
      "description": "Cross-platform UI isolation policy.",
      "anyOf": [
        {
          "$ref": "#/definitions/Ui"
        },
        {
          "type": "null"
        }
      ]
    },
    "version": {
      "description": "MXC config schema version (semver), e.g. `\"0.8.0-alpha\"`.",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "BaseProcessUi": {
      "description": "BaseProcessContainer UI isolation settings.",
      "type": "object",
      "properties": {
        "desktopSystemControl": {
          "description": "Whether desktop system control is allowed.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "ime": {
          "description": "Whether the IME (Input Method Editor) is allowed.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "isolation": {
          "description": "UI isolation level.",
          "anyOf": [
            {
              "$ref": "#/definitions/UiIsolation"
            },
            {
              "type": "null"
            }
          ]
        },
        "systemSettings": {
          "description": "System settings access level.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "ClipboardPolicy": {
      "description": "Clipboard access level.",
      "type": "string",
      "enum": [
        "none",
        "read",
        "write",
        "all"
      ]
    },
    "Containment": {
      "description": "Containment backend (abstract intent or concrete backend).",
      "oneOf": [
        {
          "description": "OS-native process sandbox (resolved per host).",
          "type": "string",
          "enum": [
            "process"
          ]
        },
        {
          "description": "Windows AppContainer / BaseContainer.",
          "type": "string",
          "enum": [
            "processcontainer"
          ]
        },
        {
          "description": "VM-class isolation (resolved per host).",
          "type": "string",
          "enum": [
            "vm"
          ]
        },
        {
          "description": "Windows Sandbox (experimental).",
          "type": "string",
          "enum": [
            "windows_sandbox"
          ]
        },
        {
          "description": "Full Linux container.",
          "type": "string",
          "enum": [
            "lxc"
          ]
        },
        {
          "description": "NanVix micro-VM (experimental).",
          "type": "string",
          "enum": [
            "microvm"
          ]
        },
        {
          "description": "Hyperlight micro-VM (experimental).",
          "type": "string",
          "enum": [
            "hyperlight"
          ]
        },
        {
          "description": "WSL container (experimental).",
          "type": "string",
          "enum": [
            "wslc"
          ]
        },
        {
          "description": "macOS Seatbelt.",
          "type": "string",
          "enum": [
            "seatbelt"
          ]
        },
        {
          "description": "Windows IsolationSession (experimental).",
          "type": "string",
          "enum": [
            "isolation_session"
          ]
        },
        {
          "description": "Unprivileged Linux bubblewrap sandbox.",
          "type": "string",
          "enum": [
            "bubblewrap"
          ]
        }
      ]
    },
    "Experimental": {
      "description": "Experimental features (only honored with `--experimental`). This block is intentionally **permissive** (no `deny_unknown_fields`): experimental backends are in flux, so the schema documents the known shapes for editor help without rejecting in-progress fields. The strict, closed contract is the stable (top-level) surface.",
      "type": "object",
      "properties": {
        "isolation_session": {
          "description": "IsolationSession backend config (Windows).",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationSession"
            },
            {
              "type": "null"
            }
          ]
        },
        "seatbelt": {
          "description": "Seatbelt backend config (pre-promotion alias).",
          "anyOf": [
            {
              "$ref": "#/definitions/Seatbelt"
            },
            {
              "type": "null"
            }
          ]
        },
        "test": {
          "description": "Placeholder feature for testing experimental infrastructure.",
          "anyOf": [
            {
              "$ref": "#/definitions/TestFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "windows_sandbox": {
          "description": "Windows Sandbox backend config.",
          "anyOf": [
            {
              "$ref": "#/definitions/WindowsSandbox"
            },
            {
              "type": "null"
            }
          ]
        },
        "wslc": {
          "description": "WSL container backend config.",
          "anyOf": [
            {
              "$ref": "#/definitions/Wslc"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "Fallback": {
      "description": "AppContainer DACL-mutation fallback policy.",
      "type": "object",
      "properties": {
        "allowDaclMutation": {
          "description": "Allow the runner to mutate DACLs as a fallback.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "Filesystem": {
      "description": "Filesystem access policy.",
      "type": "object",
      "properties": {
        "deniedPaths": {
          "description": "Paths explicitly denied (override broader allow rules).",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "readonlyPaths": {
          "description": "Paths the process can read but not write.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "readwritePaths": {
          "description": "Paths the process can read and write.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "IsolationConfigurationId": {
      "description": "IsolationSession sizing profile.",
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large",
        "composable"
      ]
    },
    "IsolationSession": {
      "description": "IsolationSession backend config. Carries both the one-shot fields (`configurationId`, `user`) and the per-phase state-aware nesting (`provision` / `start` / `stop` / `deprovision`).",
      "type": "object",
      "properties": {
        "configurationId": {
          "description": "Sizing profile (one-shot).",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationConfigurationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "deprovision": {
          "description": "State-aware deprovision-phase configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationSessionPhase"
            },
            {
              "type": "null"
            }
          ]
        },
        "provision": {
          "description": "State-aware provision-phase configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationSessionPhase"
            },
            {
              "type": "null"
            }
          ]
        },
        "start": {
          "description": "State-aware start-phase configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationSessionPhase"
            },
            {
              "type": "null"
            }
          ]
        },
        "stop": {
          "description": "State-aware stop-phase configuration.",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationSessionPhase"
            },
            {
              "type": "null"
            }
          ]
        },
        "user": {
          "description": "Optional Entra cloud-agent user bundle (one-shot).",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationUser"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "IsolationSessionPhase": {
      "description": "Per-phase IsolationSession configuration (state-aware lifecycle).",
      "type": "object",
      "properties": {
        "configurationId": {
          "description": "Sizing profile for this phase.",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationConfigurationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "user": {
          "description": "Entra cloud-agent user bundle for this phase.",
          "anyOf": [
            {
              "$ref": "#/definitions/IsolationUser"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "IsolationUser": {
      "description": "Entra cloud-agent user bundle. Reachable only under the permissive `experimental` surface, so unknown fields are tolerated (forward-compat).",
      "type": "object",
      "required": [
        "upn",
        "wamToken"
      ],
      "properties": {
        "upn": {
          "description": "User principal name.",
          "type": "string"
        },
        "wamToken": {
          "description": "Short-lived WAM bearer token (passed verbatim to the OS service).",
          "type": "string"
        }
      }
    },
    "LaunchMethod": {
      "description": "Seatbelt inner-process launch method.",
      "oneOf": [
        {
          "description": "sandbox_init() + exec (default). Works for third-party GUI apps.",
          "type": "string",
          "enum": [
            "exec"
          ]
        },
        {
          "description": "Launch via macOS LaunchServices (`open`), then apply the sandbox to the inner shell via sandbox-exec. Required for apps with launch constraints.",
          "type": "string",
          "enum": [
            "open"
          ]
        }
      ]
    },
    "Lifecycle": {
      "description": "Container lifecycle settings.",
      "type": "object",
      "properties": {
        "destroyOnExit": {
          "description": "Destroy the container when the process exits (default true).",
          "type": [
            "boolean",
            "null"
          ]
        },
        "preservePolicy": {
          "description": "Preserve the applied policy after exit (default false).",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "Lxc": {
      "description": "LXC container settings.",
      "type": "object",
      "properties": {
        "distribution": {
          "description": "Distribution image (e.g. `alpine`).",
          "type": [
            "string",
            "null"
          ]
        },
        "release": {
          "description": "Distribution release (e.g. `3.23`).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "Network": {
      "description": "Network access policy.",
      "type": "object",
      "properties": {
        "allowLocalNetwork": {
          "description": "Allow binding/listening on local IPs and accepting inbound connections.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "allowedHosts": {
          "description": "Hosts explicitly allowed.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "blockedHosts": {
          "description": "Hosts explicitly blocked.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "defaultPolicy": {
          "description": "Default outbound policy when no host rule matches.",
          "anyOf": [
            {
              "$ref": "#/definitions/NetworkPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "enforcementMode": {
          "description": "How the policy is enforced.",
          "anyOf": [
            {
              "$ref": "#/definitions/NetworkEnforcement"
            },
            {
              "type": "null"
            }
          ]
        },
        "proxy": {
          "description": "Proxy configuration (one of localhost / builtinTestServer / url).",
          "anyOf": [
            {
              "$ref": "#/definitions/Proxy"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "NetworkEnforcement": {
      "description": "Network enforcement mechanism.",
      "oneOf": [
        {
          "description": "Per-process capability-based filtering.",
          "type": "string",
          "enum": [
            "capabilities"
          ]
        },
        {
          "description": "Host firewall rules.",
          "type": "string",
          "enum": [
            "firewall"
          ]
        },
        {
          "description": "Both capability and firewall enforcement.",
          "type": "string",
          "enum": [
            "both"
          ]
        }
      ]
    },
    "NetworkPolicy": {
      "description": "Default network policy.",
      "type": "string",
      "enum": [
        "allow",
        "block"
      ]
    },
    "Phase": {
      "description": "State-aware lifecycle phase.",
      "type": "string",
      "enum": [
        "provision",
        "start",
        "exec",
        "stop",
        "deprovision"
      ]
    },
    "PortMapping": {
      "description": "A single host → container port forward. Reachable only under the permissive `experimental` surface, so unknown fields are tolerated (forward-compat).",
      "type": "object",
      "required": [
        "containerPort",
        "windowsPort"
      ],
      "properties": {
        "containerPort": {
          "description": "Container port.",
          "type": "integer",
          "minimum": 1.0,
          "maximum": 65535.0
        },
        "protocol": {
          "description": "Transport protocol for the mapping. Only `tcp` is currently supported.",
          "anyOf": [
            {
              "$ref": "#/definitions/TransportProtocol"
            },
            {
              "type": "null"
            }
          ]
        },
        "windowsPort": {
          "description": "Host (Windows) port.",
          "type": "integer",
          "minimum": 1.0,
          "maximum": 65535.0
        }
      }
    },
    "Process": {
      "description": "Process execution settings.",
      "type": "object",
      "properties": {
        "commandLine": {
          "description": "Command line (or script) to execute.",
          "type": [
            "string",
            "null"
          ]
        },
        "cwd": {
          "description": "Working directory for the process.",
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "description": "Environment variables as `\"KEY=VALUE\"` strings.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "timeout": {
          "description": "Wall-clock timeout in milliseconds.",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "ProcessContainer": {
      "description": "ProcessContainer-specific settings.",
      "type": "object",
      "properties": {
        "capabilities": {
          "description": "AppContainer capabilities (e.g. `internetClient`, `registryRead`).",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "learningMode": {
          "description": "AppContainer permissive learning mode.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "leastPrivilege": {
          "description": "Enforce least-privilege mode.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "ui": {
          "description": "BaseProcessContainer UI settings (Windows).",
          "anyOf": [
            {
              "$ref": "#/definitions/BaseProcessUi"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "Proxy": {
      "description": "Proxy configuration. Exactly one variant applies.",
      "type": "object",
      "properties": {
        "builtinTestServer": {
          "description": "Have wxc launch its own built-in test proxy.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "localhost": {
          "description": "External localhost proxy port.",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1.0,
          "maximum": 65535.0
        },
        "url": {
          "description": "Proxy URL (parsed into host:port).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "Seatbelt": {
      "description": "macOS Seatbelt backend configuration.",
      "type": "object",
      "properties": {
        "extraMachLookups": {
          "description": "Additional Mach service global-names the inner process may resolve.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "guiAccess": {
          "description": "Allow GUI (WindowServer) access.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "keychainAccess": {
          "description": "Allow Keychain access.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "launchMethod": {
          "description": "Inner process launch method.",
          "anyOf": [
            {
              "$ref": "#/definitions/LaunchMethod"
            },
            {
              "type": "null"
            }
          ]
        },
        "nestedPty": {
          "description": "Attach the inner process to a nested pty (default true).",
          "type": [
            "boolean",
            "null"
          ]
        },
        "profileOverride": {
          "description": "Replace the generated profile entirely (advanced/testing escape hatch).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "TestFeature": {
      "description": "Placeholder experimental feature.",
      "type": "object",
      "properties": {
        "message": {
          "description": "Message to log when the feature is applied.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TransportProtocol": {
      "description": "Port-forward transport protocol. Only `tcp` is currently supported by the vendored WSLC SDK runtime; `udp` is rejected at parse time.",
      "type": "string",
      "enum": [
        "tcp"
      ]
    },
    "Ui": {
      "description": "Cross-platform UI isolation policy.",
      "type": "object",
      "properties": {
        "clipboard": {
          "description": "Clipboard access level.",
          "anyOf": [
            {
              "$ref": "#/definitions/ClipboardPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "disable": {
          "description": "Disable all UI access (default true).",
          "type": [
            "boolean",
            "null"
          ]
        },
        "injection": {
          "description": "Allow UI injection.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "UiIsolation": {
      "description": "Desktop UI isolation level.",
      "type": "string",
      "enum": [
        "desktop",
        "handles",
        "atoms",
        "container"
      ]
    },
    "WindowsSandbox": {
      "description": "Windows Sandbox backend config.",
      "type": "object",
      "properties": {
        "daemonPipeName": {
          "description": "Daemon named-pipe override.",
          "type": [
            "string",
            "null"
          ]
        },
        "idleTimeout": {
          "description": "Idle timeout (legacy seconds field).",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0.0
        },
        "idleTimeoutMs": {
          "description": "Idle timeout before teardown (ms).",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0.0
        }
      }
    },
    "Wslc": {
      "description": "WSL container backend config.",
      "type": "object",
      "properties": {
        "cpuCount": {
          "description": "vCPU count.",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0.0
        },
        "gpu": {
          "description": "Enable GPU passthrough.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "image": {
          "description": "Container image reference.",
          "type": [
            "string",
            "null"
          ]
        },
        "imageTarPath": {
          "description": "Path to a local image tarball.",
          "type": [
            "string",
            "null"
          ]
        },
        "memoryMb": {
          "description": "Memory limit (MB).",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0.0
        },
