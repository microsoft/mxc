<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Microsoft.Mxc.Sdk</RootNamespace>
    <AssemblyName>Microsoft.Mxc.Sdk</AssemblyName>
    <Version>0.7.0</Version>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <Description>C# SDK for MXC (Microsoft eXecution Container), binding the native mxc_ffi library.</Description>
  </PropertyGroup>

  <!-- The C# P/Invoke layer (Native/NativeMethods.g.cs) is generated by
       csbindgen from the Rust FFI and is NOT committed (gitignored). It is
       (re)generated at build time by the GenerateNativeBindings target below,
       which builds mxc_ffi with its `dotnetsdk` feature. Exclude any stale
       on-disk copy from the default glob and add it back explicitly so exactly
       one Compile item exists whether or not the file is present at evaluation. -->
  <PropertyGroup>
    <MxcSrcDir>$(MSBuildProjectDirectory)/../../../src</MxcSrcDir>
    <MxcGeneratedBindings>$(MSBuildProjectDirectory)/Native/NativeMethods.g.cs</MxcGeneratedBindings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Native/NativeMethods.g.cs" />
    <Compile Include="Native/NativeMethods.g.cs" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.Mxc.Sdk.Tests" />
  </ItemGroup>

  <Target Name="GenerateNativeBindings"
          BeforeTargets="CoreCompile"
          Inputs="$(MxcSrcDir)/ffi/mxc_ffi/src/lib.rs;$(MxcSrcDir)/ffi/mxc_ffi/src/streaming.rs;$(MxcSrcDir)/ffi/mxc_ffi/src/state_aware.rs;$(MxcSrcDir)/ffi/mxc_ffi/build.rs"
          Outputs="$(MxcGeneratedBindings)">
    <Message Importance="high" Text="mxc: generating C# P/Invoke bindings (cargo build -p mxc_ffi --features dotnetsdk)" />
    <Exec Command="cargo build -p mxc_ffi --features dotnetsdk" WorkingDirectory="$(MxcSrcDir)" />
    <Error Condition="!Exists('$(MxcGeneratedBindings)')"
           Text="Binding generation did not produce $(MxcGeneratedBindings). Ensure the Rust toolchain (cargo) is installed and on PATH." />
  </Target>

  <!-- Native mxc_ffi library for the host platform, staged into runtimes/<rid>/native
       by the platform's build script (build.bat stages the Windows RIDs today;
       build.sh / build-mac.sh do not yet stage theirs), and packed as NuGet
       runtime assets. A given build only produces its own platform's native
       library, so a multi-RID package requires packing on/with each platform.
       For local dev/test the native lib is instead located by
       NativeLibraryResolver from the Cargo target dir. -->
  <ItemGroup>
    <None Include="runtimes/**/*" Pack="true" PackagePath="runtimes/" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
