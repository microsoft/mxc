{
  "name": "@microsoft/mxc-sdk",
  "version": "0.1.5",
  "description": "TypeScript SDK for MXC (Microsoft eXecution Containers)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [ "bin/", "dist/" ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wxc",
    "sandbox",
    "security",
    "appcontainer",
    "windows",
    "node-pty"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "node-pty": "^1.2.0-beta.12"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": ["win32", "linux"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
