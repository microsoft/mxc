{
  "version": "0.4.0-alpha",
  "containerId": "UI-Test-04",
  "containment": "appcontainer",
  "process": {
    "commandLine": "cmd.exe /c \"echo test | clip.exe && echo FAIL: wrote clipboard || echo PASS: clipboard write blocked\"",
    "timeout": 15000
  },
  "appContainer": {
    "capabilities": []
  },
  "ui": {
    "disable": false,
    "clipboard": "read",
    "injection": false,
    "isolation": "desktop",
    "desktopSystemControl": false,
    "systemSettings": "none",
    "ime": false
  }
}
