{
  "version": "0.4.0-alpha",
  "containerId": "CLI-LXC-Filesystem-Test",
  "containment": "lxc",
  "platform": "linux",
  "process": {
    "commandLine": "wget -qO- https://api.github.com/zen"
  },
  "lifecycle": {
    "destroyOnExit": true
  },
  "lxc": {
    "distribution": "alpine",
    "release": "3.20"
  },
  "network": {
    "defaultPolicy": "block",
    "enforcementMode": "firewall",
    "allowedHosts": ["api.github.com"],
    "blockedHosts": ["evil.example.com"]
  }
}