{
  "version": "0.5.0-alpha",
  "containerId": "wslc-filesystem-test",
  "containment": "wslc",
  "process": {
    "commandLine": "ls -la /mnt/c/workspace && echo 'Filesystem test passed'",
    "cwd": "C:\\workspace"
  },
  "filesystem": {
    "readwritePaths": ["C:\\workspace"]
  },
  "network": {
    "defaultPolicy": "allow"
  },
  "experimental": {
    "wslc": {
      "image": "alpine:latest",
      "cpuCount": 2,
      "memoryMb": 1024
    }
  }
}
