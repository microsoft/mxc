{
  "version": "0.6.0-alpha",
  "containerId": "CLI-Bubblewrap-Network-Firewall",
  "containment": "bubblewrap",
  "platform": "linux",
  "process": {
    "commandLine": "wget -qO- https://api.github.com/zen"
  },
  "network": {
    "defaultPolicy": "block",
    "enforcementMode": "firewall",
    "allowedHosts": ["api.github.com"],
    "blockedHosts": ["evil.example.com"]
  }
}
