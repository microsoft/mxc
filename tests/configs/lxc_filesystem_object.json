{
  "version": "0.4.0-alpha",
  "containerId": "CLI-LXC-Object-Validation",
  "containment": "lxc",
  "process": {
    "commandLine": "if cat /mnt/objdata/secret.txt 2>/dev/null; then echo OBJECT_LEAK; else echo OBJECT_MASKED_OK; fi"
  },
  "lifecycle": {
    "destroyOnExit": true
  },
  "lxc": {
    "distribution": "alpine",
    "release": "3.23"
  },
  "filesystem": {
    "readwritePaths": ["/mnt/objdata"],
    "deniedPaths": ["/mnt/objlink"]
  }
}
