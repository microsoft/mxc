{
  "version": "0.4.0-alpha",
  "containerId": "CLI-LXC-Filesystem-Test",
  "containment": "lxc",
  "process": {
    "commandLine": "cat /mnt/readonly/test.txt && echo 'write test' > /mnt/readwrite/output.txt"
  },
  "lifecycle": {
    "destroyOnExit": true
  },
  "lxc": {
    "distribution": "alpine",
    "release": "3.23"
  },
  "filesystem": {
    "readonlyPaths": ["/mnt/readonly"],
    "readwritePaths": ["/mnt/readwrite"]
  }
}