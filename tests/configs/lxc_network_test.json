{
  "version": "0.6.0-alpha",
  "containerId": "CLI-LXC-Network-Test",
  "containment": "lxc",
  "process": {
    "commandLine": "wget -qO- https://api.github.com/zen"
  },
  "lifecycle": {
    "destroyOnExit": true
  },
  "lxc": {
    "distribution": "alpine",
    "release": "3.23"
  },
  "network": {
    "defaultPolicy": "block",
    "enforcementMode": "firewall",
    "allowedHosts": ["api.github.com"],
    "blockedHosts": ["evil.example.com"]
  }
}