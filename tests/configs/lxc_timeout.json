{
  "version": "0.6.0-alpha",
  "containerId": "CLI-LXC-Timeout-Test",
  "containment": "lxc",
  "process": {
    "commandLine": "echo 'Starting long task'; sleep 120; echo 'Should not reach here'",
    "timeout": 5000
  },
  "lifecycle": {
    "destroyOnExit": true
  },
  "lxc": {
    "distribution": "alpine",
    "release": "3.23"
  }
}
