{
  "version": "0.7.0-alpha",
  "containerId": "PLM-SysColor-Set-Basic",
  "containment": "processcontainer",
  "process": {
    "commandLine": "plmtester.exe system-param --action set-sys-colors --index 1 --value 0x00112233",
    "timeout": 30000
  },
  "ui": {
    "disable": false
  },
  "processContainer": {
    "ui": {
      "systemSettings": "none"
    }
  }
}
