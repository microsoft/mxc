{
  "version": "0.6.0-alpha",
  "containerId": "wslc-ghcr-registry",
  "containment": "wslc",
  "process": {
    "commandLine": "echo 'Image pulled from GHCR' && cat /etc/alpine-release"
  },
  "network": {
    "defaultPolicy": "allow"
  },
  "experimental": {
    "wslc": {
      "image": "ghcr.io/linuxserver/baseimage-alpine:3.21"
    }
  }
}
