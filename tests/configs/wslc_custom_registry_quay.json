{
  "version": "0.6.0-alpha",
  "containerId": "wslc-quay-registry",
  "containment": "wslc",
  "process": {
    "commandLine": "echo 'Image pulled from Quay' && cat /etc/os-release | head -4"
  },
  "network": {
    "defaultPolicy": "allow"
  },
  "experimental": {
    "wslc": {
      "image": "quay.io/fedora/fedora-minimal:latest"
    }
  }
}
