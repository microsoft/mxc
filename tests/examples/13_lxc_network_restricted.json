{
  "version": "0.6.0-alpha",
  "containerId": "CLI-LXC-NetworkRestricted",
  "containment": "lxc",
  "process": {
    "commandLine": "wget -qO- https://api.github.com/zen || echo 'Network blocked as expected'"
  },
  "lifecycle": {
    "destroyOnExit": true
  },
  "lxc": {
    "distribution": "alpine",
    "release": "3.20"
  },
  "network": {
    "defaultPolicy": "block",
    "enforcementMode": "firewall",
    "allowedHosts": ["api.github.com"]
  }
}
