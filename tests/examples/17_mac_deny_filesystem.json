{
    "$schema": "../schemas/stable/mxc-config.schema.0.7.0-alpha.json",
    "version": "0.7.0-alpha",
    "containment": "seatbelt",
    "process": {
        "commandLine": "ls /Users && echo FS_ALLOWED || echo FS_BLOCKED",
        "timeout": 10000
    },
    "filesystem": {
        "readwritePaths": [
            "/tmp"
        ],
        "deniedPaths": [
            "/Users"
        ]
    },
    "network": {
        "defaultPolicy": "block"
    }
}
