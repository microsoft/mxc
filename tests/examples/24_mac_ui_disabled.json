{
    "$schema": "../schemas/dev/mxc-config.schema.0.7.0-dev.json",
    "version": "0.7.0-alpha",
    "containment": "seatbelt",
    "process": {
        "commandLine": "/bin/sh -c 'echo sandbox_clip_test | /usr/bin/pbcopy; /usr/bin/pbpaste'",
        "timeout": 10000
    },
    "network": {
        "defaultPolicy": "block"
    },
    "ui": {
        "disable": true
    },
    "seatbelt": {
        "mode": "exec"
    }
}
